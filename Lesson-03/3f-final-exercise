<!DOCTYPE html>
<html>
  <head>
    <style>
      .Amazon{
        font-size: 20px;
        cursor: pointer;
      }
      .Amazon:hover{
        color: rgb(204, 0, 0);
      }
      .nike-shoe-price{
        font-size: 25px;
        font-weight: bold;
        color: green;
      }
      .cart-button{
        border: none;
        margin-right: 10px;
        height: 30px;
        width: 100px;
        font-weight: bold;
        border-radius: 15px;
        background-color: rgb(249, 217, 76);
        transition: background-color 0.1s,opacity 0.1s;
        cursor:pointer;
      }
      .cart-button:hover{
        background-color: rgb(247, 202, 0);
        box-shadow: 0 5px 4px rgb(0,0,0,0.2);
      }
      .cart-button:active{
        opacity: 0.7;
        box-shadow: 0 5px 4px rgb(0,0,0,0.1);
      }
      .buy-button{
        border:none;
        height:30px;
        width:100px;
        border-radius: 15px;
        font-weight: bold;
        background-color: orange;
        cursor:pointer;
        transition: background-color 0.1s,opacity 0.1s;
      }
      .buy-button:hover{
        background-color:rgb(217, 144, 9);
        box-shadow: 0 5px 4px rgb(0,0,0,0.2);
      }
      .buy-button:active{
        opacity: 0.7;
         box-shadow: 0 5px 4px rgb(0,0,0,0.1);
      }
    </style>
  </head>
  <body>
    <a href="https://www.amazon.com/" class="Amazon">Back to Amazon</a>
    <h1 class="Nike-shoe">Nike Black Running Shoes</h1>
    <p class="nike-shoe-price">$39 - in stock.</p>
    <p style="font-size: 25px">Free delivery tomorrow.</p>
    <button class="cart-button">Add to cart</button>
    <button class="buy-button">Buy now</button>
  </body>
</html>
