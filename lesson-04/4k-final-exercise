<html>
  <head>
    <style>
      .stretch-button{
        border: none;
        color: white;
        background-color: green;
        cursor: pointer;
        font-size: 18px;
        padding: 10 15 10 15;
        margin-left: 10px;
        margin-right: 15px;
        transition: padding 0.5s,margin 0.5s;
         
      }
      .stretch-button:hover{
        padding: 10 25 10 25;
        margin-right: 5px;
        margin-left: 0px;
        
        
        
      }
    </style>
  </head>
  <body>
    <button class="stretch-button">One</button>
    <button class="stretch-button">Two</button>
    <button class="stretch-button">Three</button>
  </body>
</html>
